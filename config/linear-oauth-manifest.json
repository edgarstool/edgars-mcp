{
  "display": {
    "name": "Hermes Agent",
    "description": "Hermes Linear agent app for delegated issue work and Agent Session events."
  },
  "developer": {
    "name": "Edgar AI Guild"
  },
  "oauth": {
    "client_name": "Hermes Agent",
    "client_uri": "https://github.com/Edgars-tool/hermes-agent",
